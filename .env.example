# Copy to .env (gitignored) and fill in, or export these in your shell.
# Values already set in the shell environment take precedence over .env.

# Castorini search backend token (for support assessment + E2E create-input)
CASTORINI_API_TOKEN="YOUR_CASTORINI_API_TOKEN_HERE"

# AWS Bedrock credentials (alternative to ~/.aws/credentials)
# For production, prefer using ~/.aws/credentials and load with setup_from_profile()
# AWS_ACCESS_KEY_ID="YOUR_AWS_ACCESS_KEY_ID"
# AWS_SECRET_ACCESS_KEY="YOUR_AWS_SECRET_ACCESS_KEY"
# AWS_REGION="us-west-2"
# AWS_SESSION_TOKEN="YOUR_SESSION_TOKEN"  # Optional, for temporary credentials
